# Django Settings
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=your-app-name.onrender.com,localhost,127.0.0.1

# Database (Render will automatically provide DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:port/database

# Note: On Render, you don't need to set DATABASE_URL manually.
# Render automatically sets it when you create a PostgreSQL database.
